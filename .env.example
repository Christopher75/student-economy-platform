# Copy this file to .env and fill in the values for local development
# NEVER commit .env to git

SECRET_KEY=django-insecure-change-this-in-production-use-a-long-random-string

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Leave blank to use SQLite locally
DATABASE_URL=

# ── Email ──────────────────────────────────────────────────────────────────────
# Local dev: use console backend — OTP codes print to the terminal, no SMTP needed.
# Production (Render): switch to smtp backend and fill in the SMTP credentials below.

# Dev (default — prints emails to the terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production — uncomment and set the four SMTP vars, then change EMAIL_BACKEND:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Gmail account that sends platform emails (use an App Password, not your real password)
EMAIL_HOST_USER=cd121012@students.cavendish.ac.ug
# Generate at: Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST_PASSWORD=

DEFAULT_FROM_EMAIL=Student Economy Platform <noreply@studenteconomy.ug>
