# Copy this file to .env and fill in the values for local development
# NEVER commit .env to git

SECRET_KEY=django-insecure-change-this-in-production-use-a-long-random-string

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Leave blank to use SQLite locally
DATABASE_URL=

# ── Email ──────────────────────────────────────────────────────────────────────
# Local dev: console backend prints OTP codes to the terminal — no account needed.
# Production: Resend HTTP API (render.onrender.com blocks outbound SMTP port 587).
#   1. Sign up free at resend.com (3,000 emails/month)
#   2. Create an API key in the Resend dashboard
#   3. Set EMAIL_BACKEND and RESEND_API_KEY on Render (or below for local testing)

# Dev (default)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production — Brevo HTTP API (free 300/day, verify a Gmail sender, no domain needed)
# EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=

DEFAULT_FROM_EMAIL=Student Economy Platform <noreply@studenteconomy.ug>
