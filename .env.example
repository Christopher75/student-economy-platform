# Copy this file to .env and fill in the values for local development
# NEVER commit .env to git

SECRET_KEY=django-insecure-change-this-in-production-use-a-long-random-string

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Leave blank to use SQLite locally
DATABASE_URL=

# Email (leave as console backend for local dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@studenteconomy.ug
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
